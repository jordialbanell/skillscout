# Apify - for Instagram and TikTok scraping
# Get your token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# Anthropic - for Claude analysis
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub (optional but recommended - increases API rate limits from 60 to 5000/hr)
# Create a token at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=your_github_token_here
